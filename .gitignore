# ---------------------------------------------------------------------------
# Datasets & heavy binary artifacts (never commit data to git)
#   SEED / DREAMER raw + derived features live under Data/ and stay local.
#   Root-anchored so it does NOT also ignore the src/eeg_gnn/data package
#   (git is case-insensitive on Windows: bare "Data/" would match "data/").
# ---------------------------------------------------------------------------
/Data/
*.mat
*.pkl
*.npy
*.pth
*.edf

# ---------------------------------------------------------------------------
# Regenerable experiment outputs (produced by the training pipeline)
# ---------------------------------------------------------------------------
Errors/
Results/
Params/
Analysis/
Analysis_Results/
Trial_Plots/
Features/

# ---------------------------------------------------------------------------
# Reference material / scratch (kept locally, not part of the codebase)
# ---------------------------------------------------------------------------
Models_for_EEG_on_the_Datasets/
Dataset_Papers/
GNN_papers/
What_to_do/
OTHER RUNS FOR LATER/
NOTES AND COURSE OF ACTION/

# Heavy exploratory notebooks (kept locally)
GCN_demo.ipynb
preprocessing_EDF.ipynb

