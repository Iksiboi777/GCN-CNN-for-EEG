# Ignore Python cache and local virtual environment
__pycache__/
*.py[cod]

# ...existing code...
# Local virtual environment for this project
gcn_venv/

*mat
*pkl

# --- GLOBAL IGNORE FOR NPY FILES ---
# This ensures that even if a folder is whitelisted below, the .npy files inside it are ignored.
*.npy

.venv/

# --- RESULTS FOLDER RULES ---
# 1. Ignore everything in Results by default
Results/*

# 2. Whitelist GCN_DE_4s (parent folder)
!Results/GCN_DE_4s/
# 3. Ignore everything inside GCN_DE_4s by default (so we only pick specific attempts)
Results/GCN_DE_4s/*
# 4. Whitelist Attempts 28-34
!Results/GCN_DE_4s/Attempt_28*/
!Results/GCN_DE_4s/Attempt_29*/
!Results/GCN_DE_4s/Attempt_30*/
!Results/GCN_DE_4s/Attempt_31*/
